# Core platform security (use separate values in development, preview, and production)
PLATFORM_SESSION_SECRET=replace-with-at-least-32-random-characters
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
SECURITY_HASH_PEPPER=replace-with-a-separate-32-byte-random-value
WIDGET_SIGNING_SECRET=replace-with-a-separate-32-byte-random-value
CRON_SECRET=replace-with-a-long-random-value
PLATFORM_HOSTS=gutterquote.example.com,www.gutterquote.example.com
TENANT_ROOT_DOMAIN=quotes.gutterquote.example.com
NEXT_PUBLIC_APP_URL=https://gutterquote.example.com

# Google Ads conversion tracking (completed contractor signup)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-00000000000
NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_LABEL=replace_with_conversion_label

# Serverless PostgreSQL transaction pooler; the production application role must not own tables
DATABASE_URL=postgresql://app_role:password@pooler.example.com:6543/gutterquote?sslmode=require
# Restricted operational role used only by schema migration, webhooks, hostname lookup, workers, and retention.
PLATFORM_DATABASE_URL=postgresql://platform_role:password@pooler.example.com:6543/gutterquote?sslmode=require
DATABASE_POOL_MAX=5

# Clerk Organizations and signed webhook
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Set privateMetadata.platformRole="admin" only on approved platform staff users and enforce MFA in Clerk.

# Redis-backed distributed rate limiting
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Cloudflare Turnstile (required before the first production render)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=xxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxx

# Private image storage; configure a 24-hour lifecycle rule as a second cleanup layer
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx

# KMS-injected, base64-encoded 32-byte AES key. Add V2 before rotating and update PII_ENCRYPTION_KEY_VERSION.
PII_ENCRYPTION_KEY_VERSION=1
PII_ENCRYPTION_KEY_V1=base64-encoded-32-byte-key

# Google APIs used server-side for address, imagery, and measurement
GOOGLE_MAPS_API_KEY=your_google_maps_platform_api_key

# Gemini image generation and platform safeguards
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
MAX_TENANT_RENDER_CONCURRENCY=10
MAX_TENANT_DAILY_RENDERS=100
RENDER_PLATFORM_PAUSED=false

# Stripe billing and signed webhook
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_PRICE_ID=price_gutterquote_199_monthly
STRIPE_INTRO_COUPON_ID=gutterquote_intro_50_off_3_months
STRIPE_SETUP_PRICE_ID=price_gutterquote_299_setup
STRIPE_RENDER_PRICE_ID=price_render_credit_pack
RENDER_CREDITS_PER_PACK=100
SUBSCRIPTION_GRACE_DAYS=7

# One shared Vercel project and managed domains
VERCEL_TOKEN=your_least_privilege_vercel_access_token
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxx
VERCEL_PLATFORM_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxx
VERCEL_PLATFORM_PROJECT_NAME=gutterquote-platform

# Domain registrant used only for an approved domain purchase
DOMAIN_REGISTRANT_FIRST_NAME=First
DOMAIN_REGISTRANT_LAST_NAME=Last
DOMAIN_REGISTRANT_EMAIL=domains@example.com
DOMAIN_REGISTRANT_PHONE=+19045551212
DOMAIN_REGISTRANT_ADDRESS1=123 Business Street
DOMAIN_REGISTRANT_ADDRESS2=
DOMAIN_REGISTRANT_CITY=Jacksonville
DOMAIN_REGISTRANT_STATE=FL
DOMAIN_REGISTRANT_ZIP=32202
DOMAIN_REGISTRANT_COUNTRY=US
DOMAIN_REGISTRANT_COMPANY=HD Precision

# Completed-lead email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
LEAD_FROM_EMAIL=GutterQuote Leads <leads@your-verified-domain.com>
LEAD_EMAIL_CRON_BATCH_SIZE=25
